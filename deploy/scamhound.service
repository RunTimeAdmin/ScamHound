[Unit]
Description=ScamHound Crypto Risk Scanner
After=network.target

[Service]
Type=simple
User=scamhound
Group=scamhound
WorkingDirectory=/opt/scamhound/scamhound
EnvironmentFile=/opt/scamhound/.env
ExecStart=/opt/scamhound/venv/bin/python main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/scamhound/scamhound

[Install]
WantedBy=multi-user.target
